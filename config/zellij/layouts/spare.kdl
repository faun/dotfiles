// Spare, tmux-style status line via the zjstatus plugin.
//
// Replaces zellij's built-in compact-bar, which hardcodes a "Zellij (<session>)"
// ribbon that can't be turned off. This mirrors the dotfiles tmux status line
// (tmux.conf): the session in a light block on the left, then the current mode,
// with the tab / "window" list in the center. Colors come from tmux.conf's
// status bar — #282a2e background, #373b41 active-tab block, #b4b7b4 light,
// #969896 dim.
//
// The plugin wasm is fetched by install/06_zellij.sh to
// ~/.local/share/zellij/plugins/zjstatus.wasm (pinned, not vendored in git).
layout {
    default_tab_template {
        children
        pane size=1 borderless=true {
            plugin location="file:~/.local/share/zellij/plugins/zjstatus.wasm" {
                format_left   "#[fg=#373b41,bg=#b4b7b4,bold] {session} #[fg=#c5c8c6,bg=#282a2e] {mode}"
                format_center "{tabs}"
                format_right  ""
                format_space  "#[bg=#282a2e]"

                border_enabled "false"

                // Current mode — the piece the built-in tab-bar drops. The tmux
                // prefix layer (Ctrl+a) is highlighted, matching tmux's accent.
                mode_normal       "#[fg=#969896] normal "
                mode_tmux         "#[fg=#de935f,bold] tmux "
                mode_locked       "#[fg=#cc6666,bold] locked "
                mode_pane         "#[fg=#81a2be] pane "
                mode_tab          "#[fg=#81a2be] tab "
                mode_resize       "#[fg=#81a2be] resize "
                mode_move         "#[fg=#81a2be] move "
                mode_scroll       "#[fg=#b294bb] scroll "
                mode_search       "#[fg=#b294bb] search "
                mode_enter_search "#[fg=#b294bb] search "
                mode_session      "#[fg=#8abeb7] session "
                mode_rename_tab   "#[fg=#f0c674] rename "
                mode_rename_pane  "#[fg=#f0c674] rename "

                // Tabs = tmux windows: active tab in a #373b41 block, others dim.
                tab_normal "#[fg=#969896,bg=#282a2e] {name} "
                tab_active "#[fg=#b4b7b4,bg=#373b41,bold] {name} "
            }
        }
    }
}
